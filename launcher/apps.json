{
  "apps": [
    {
      "id": "studio",
      "name": "llmlab Studio",
      "description": "検索・要約・レポート・数値抽出・グラフをブラウザ1画面で行うワンストップUI",
      "icon": "studio",
      "cwd": "../jupyter-local-llm",
      "command": [
        "{python}",
        "-m",
        "llmlab.app",
        "--port",
        "8765"
      ],
      "env": {
        "PYTHONPATH": "src"
      },
      "url": "http://127.0.0.1:8765",
      "wait_port": 8765
    },
    {
      "id": "loop",
      "name": "llmlab Loop",
      "description": "目標を投げると 計画→実行→検証→再試行 を自動で回す自律ループ。定期実行・Webhook・人間承認",
      "icon": "loop",
      "cwd": "../jupyter-local-llm",
      "command": [
        "{python}",
        "-m",
        "llmlab.loopsys",
        "--port",
        "8766"
      ],
      "env": {
        "PYTHONPATH": "src"
      },
      "url": "http://127.0.0.1:8766",
      "wait_port": 8766
    },
    {
      "id": "copilot-research",
      "name": "Copilot Research",
      "description": "M365 Copilot（Researcher）を擬似GEPAで駆動。依頼→LocalLLMで目次→章ごとにCopilotリサーチ→統合レポート",
      "icon": "research",
      "cwd": "../jupyter-local-llm",
      "command": [
        "{python}",
        "-m",
        "llmlab.copilotresearch",
        "--port",
        "8767"
      ],
      "env": {
        "PYTHONPATH": "src"
      },
      "url": "http://127.0.0.1:8767",
      "wait_port": 8767
    },
    {
      "id": "jupyterlab",
      "name": "JupyterLab",
      "description": "コード補完・チャット・各種RAGのノートブック（llmlab）を動かす JupyterLab",
      "icon": "jupyter",
      "cwd": "../jupyter-local-llm",
      "command": [
        "{python}",
        "-m",
        "jupyterlab",
        "--no-browser",
        "--port",
        "8888",
        "--ServerApp.token="
      ],
      "url": "http://127.0.0.1:8888/lab",
      "wait_port": 8888
    },
    {
      "id": "agent-orchestrator",
      "name": "Agent Orchestrator",
      "description": "Codex × Claude Code × ローカルLLM のエージェント同士を協調させる（実装+レビュー / 討論 / 審判 など7戦略）",
      "icon": "agents",
      "cwd": "../../claudecode",
      "command": [
        "{python}",
        "-m",
        "agent_orchestrator",
        "serve",
        "--port",
        "8801"
      ],
      "url": "http://127.0.0.1:8801",
      "wait_port": 8801
    },
    {
      "id": "deep-research",
      "name": "Deep Research Tool",
      "description": "Web検索→調査ループ→根拠管理→ハルシネーション検証→レポート生成 まで自動で行うディープリサーチ",
      "icon": "research",
      "cwd": "../../claudecode",
      "command": [
        "{python}",
        "-c",
        "from deep_research_tool.webui.server import run_server; run_server(port=8802)"
      ],
      "url": "http://127.0.0.1:8802",
      "wait_port": 8802
    }
  ]
}
