# FermiScope 環境変数の例(実際の値は .env に置き、コミットしないでください)

# ---- アプリ ----
# 表示名(設定ファイル config/estimation.yaml の app.name より優先)
FERMISCOPE_APP_NAME=FermiScope
# データベース(デフォルト: プロジェクト直下の SQLite。PostgreSQL 例:
# postgresql+psycopg://user:pass@localhost:5432/fermiscope)
# FERMISCOPE_DATABASE_URL=sqlite:///fermiscope.db
# 許可する Host ヘッダ(DNSリバインディング対策)。既定はループバックのみ。
# LAN/外部公開時のみ、公開するホスト名をカンマ区切りで指定し、加えて
# リバースプロキシで認証をかけること(このアプリ自体に認証はありません)。
# FERMISCOPE_ALLOWED_HOSTS=fermiscope.internal.example,10.0.0.5
# 設定ディレクトリの上書き
# FERMISCOPE_CONFIG_DIR=./config
# モンテカルロ反復回数の上書き
# FERMISCOPE_MC_ITERATIONS=20000
# 1プロジェクトあたり検索回数上限の上書き
# FERMISCOPE_MAX_SEARCHES=80

# ---- 検索プロバイダ ----
# mock:  同梱のサンプル資料で動作(APIキー不要、デフォルト)
# brave: Brave Search API を使用
SEARCH_PROVIDER=mock
# BRAVE_API_KEY=your-brave-search-api-key

# ---- 生成AI(補助機能のみ。無くても動作します)----
# 起動後は GUI(トップページの「⚙ 生成AI(LLM)接続設定」)からも設定・切替できます。
# ここの環境変数は「初回起動時の初期値」として使われます。
# noop:              LLMなし(デフォルト)
# mock:              テスト用の決定論的LLM
# openai_compatible: OpenAI互換API(OpenAI 本体 / ローカルLLM: vLLM・Ollama・LM Studio / 各社ゲートウェイ)
# anthropic:         Anthropic Messages API
LLM_PROVIDER=noop

# OpenAI互換(ローカルLLM含む)を使う場合:
# LLM_API_BASE=https://api.openai.com/v1   # ローカルLLM例: http://localhost:11434/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=your-model-id                  # モデルIDはコードに固定せず、ここで指定します

# Anthropic API を使う場合:
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-sonnet-5
# ANTHROPIC_API_BASE=                      # 省略可(既定 https://api.anthropic.com)。ゲートウェイ時のみ指定

# 全プロバイダ共通(任意): プロキシ経由で接続する場合
# LLM_PROXY=http://user:pass@proxy.example:8080

# GUIで保存したLLM設定の保存先(APIキーを含むためコミット対象外の場所に)
# FERMISCOPE_LLM_SETTINGS_PATH=./llm_settings.json
