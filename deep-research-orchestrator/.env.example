# Deep Research Orchestrator — 環境設定の例
# 実値は入れないこと。secretはこのファイルにコミットしない。

# ---------- LLM provider ----------
# local | openai | anthropic
LLM_PROVIDER=local

# Local LLM (OpenAI互換API: Ollama / LM Studio / vLLM / llama.cpp server)
LOCAL_LLM_API=openai-compatible
# 例: http://host.docker.internal:11434/v1 または http://ollama:11434/v1
LOCAL_LLM_ENDPOINT=
# key不要のLocal LLMでは空のまま
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=

# OpenAI (任意。生成AI処理のみに利用。Web Search等のhosted retrievalは使わない)
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic (任意。生成AI処理のみに利用)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# ---------- Search ----------
# searxng | disabled  (有料検索APIはMVPでは利用不可)
SEARCH_PROVIDER=searxng
SEARXNG_ENDPOINT=http://searxng:8080
# SearXNG自体のsecret (compose内で使用)
SEARXNG_SECRET=

# ---------- Proxy ----------
# off | inherit | explicit
PROXY_MODE=off
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=
PROXY_CA_BUNDLE=

# ---------- Infra ----------
POSTGRES_USER=dro
POSTGRES_PASSWORD=changeme-in-production
POSTGRES_DB=dro
DATA_DIR=./data

# master key file (ホスト側パス)。scripts/gen_master_key.sh で生成する。
# DB・リポジトリとは別に保管すること。
DRO_MASTER_KEY_FILE=./secrets/dro_master_key

# Runner間shared token (任意。設定するとRunner APIが認証を要求する)
RUNNER_SHARED_TOKEN=

# ---------- Registry mirror (社内mirrorへ切替可能) ----------
PIP_INDEX_URL=https://pypi.org/simple
NPM_CONFIG_REGISTRY=https://registry.npmjs.org/

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE=http://localhost:8800
